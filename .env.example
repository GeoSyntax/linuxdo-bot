# ============================================================
# linux.do 关键词监控机器人 - 环境配置
# 复制为 .env 后填写：  cp .env.example .env
# ============================================================

# 【必填】Telegram 机器人 token（找 @BotFather 创建机器人后获得）
TG_BOT_TOKEN=

# 【可选】监控的分类：latest（最新）或分类 slug，逗号分隔
#   例：LINUXDO_CATEGORIES=latest
#   例：LINUXDO_CATEGORIES=develop,resource
LINUXDO_CATEGORIES=latest

# 【可选】采集轮询间隔（秒），默认 300（5 分钟）。别设太小，尊重社区。
POLL_INTERVAL=300

# 【可选】每轮每个列表取多少主题，默认 30
FETCH_LIMIT=30

# 【可选】是否二跳抓主题正文做更精准匹配（true 更准但更慢），默认 false
FETCH_DETAIL=false

# 【可选】采集限速：请求/秒，默认 0.33（约 3 秒 1 次），合规克制
REQUESTS_PER_SECOND=0.33

# 【可选】浏览器是否无头，默认 true（本地调试可设 false 看过盾过程）
HEADLESS=true

# 【可选】采集模式：playwright(默认,真实浏览器) | flaresolverr(cookie复用,快) | warp(CF自家IP)
FETCH_MODE=playwright
# FlareSolverr 服务地址（需先 docker run -d --name flaresolverr -p 8191:8191 ghcr.io/flaresolverr/flaresolverr:latest）
FLARESOLVERR_URL=http://127.0.0.1:8191/v1
# WARP 代理地址（需先安装 Cloudflare WARP：curl -fsSL https://pkg.cloudflareclient.com/install.sh | sudo bash）
WARP_PROXY=socks5://127.0.0.1:40000

# 【可选】采集模式：playwright(默认,真实浏览器) | flaresolverr(cookie复用,快) | warp(CF自家IP)
FETCH_MODE=playwright
# FlareSolverr 服务地址（需先 docker run -d --name flaresolverr -p 8191:8191 ghcr.io/flaresolverr/flaresolverr:latest）
FLARESOLVERR_URL=http://127.0.0.1:8191/v1
# WARP 代理地址（需先安装 Cloudflare WARP：curl -fsSL https://pkg.cloudflareclient.com/install.sh | sudo bash）
WARP_PROXY=socks5://127.0.0.1:40000

# 【可选】采集模式：playwright(默认,真实浏览器) | flaresolverr(cookie复用,快) | warp(CF自家IP)
FETCH_MODE=playwright
# FlareSolverr 服务地址（需先 docker run -d --name flaresolverr -p 8191:8191 ghcr.io/flaresolverr/flaresolverr:latest）
FLARESOLVERR_URL=http://127.0.0.1:8191/v1
# WARP 代理地址（需先安装 Cloudflare WARP：curl -fsSL https://pkg.cloudflareclient.com/install.sh | sudo bash）
WARP_PROXY=socks5://127.0.0.1:40000

# 【可选】数据库路径，默认 data/linuxdo_bot.db
DB_PATH=data/linuxdo_bot.db

# 【可选】TG API 地址（用自建反代时改，一般不用动）
TG_API_BASE=https://api.telegram.org

# ============================================================
# RAG 智能搜索（/ask 命令）配置 —— 全部可选，默认零依赖 TF-IDF + 主题列表
# ============================================================

# embedding 方式：tfidf(默认,零依赖) | local(本地语义模型) | api(OpenAI兼容)
RAG_EMBED_PROVIDER=tfidf
# local 模式的模型名（需 pip install sentence-transformers）
RAG_EMBED_MODEL=BAAI/bge-small-zh-v1.5
# api 模式的 embedding 端点
# RAG_EMBED_API_BASE=https://api.openai.com/v1
# RAG_EMBED_API_KEY=
# RAG_EMBED_API_MODEL=text-embedding-3-small

# 答案生成 LLM：rule(默认,直接给相关主题列表) | ollama(本地) | openai(云API)
RAG_LLM_PROVIDER=rule
# ollama 本地模型
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
# openai 兼容 API
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# /ask 检索返回的相关主题数
RAG_TOP_K=5
